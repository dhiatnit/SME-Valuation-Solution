# Copy this file to .env and fill in your Supabase project values.
# .env is gitignored — never commit real credentials.

# Found in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use the SERVICE ROLE key (not anon) — bypasses RLS so backend can insert.
# Keep this server-side only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Comma-separated origins allowed to call the API.
# In development you can use * to allow everything.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
